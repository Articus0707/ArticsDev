<Page x:Class="Jaina.PageModels.Home"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="560" d:DesignWidth="850"
      Title="Home" Width="850" Height="560">

    <Grid>
        <Border CornerRadius="20" Margin="10">
            <!-- Градиентный фон -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop x:Name="Stop1" Color="#007eff" Offset="0"/>
                    <GradientStop x:Name="Stop2" Color="#08162f" Offset="0.5"/>
                </LinearGradientBrush>
            </Border.Background>

            <!-- Содержимое страницы -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="743*"/>
                    <ColumnDefinition Width="107*"/>
                </Grid.ColumnDefinitions>

                <!-- Рамка -->
                <Rectangle 
    HorizontalAlignment="Left" 
    Height="27" 
    Width="248"
    Margin="296,500,0,0" 
    VerticalAlignment="Top">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF2C3E50" Offset="0.0"/>
                            <GradientStop Color="#FF3498DB" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.Effect>
                        <DropShadowEffect 
            ShadowDepth="3"
            Direction="330"
            Color="#FF2C3E50"
            Opacity="0.4"
            BlurRadius="6"/>
                    </Rectangle.Effect>
                    <Rectangle.Clip>
                        <RectangleGeometry RadiusX="13" RadiusY="13" 
            Rect="0,0,248,27"/>
                    </Rectangle.Clip>
                </Rectangle>

                <!-- Логотип -->
                <Image x:Name="Logo" HorizontalAlignment="Left" Height="500" VerticalAlignment="Top" Width="500" 
                       Margin="170,20,0,0" Source="/assets/images/dragon.png">
                    <Image.Effect>
                        <DropShadowEffect x:Name="LogoEffect" BlurRadius="150" Color="#9c00ff" Opacity="0.8"/>
                    </Image.Effect>
                </Image>

                <!-- Добавляем MediaElement для воспроизведения видео -->

                <!-- Основной заголовок -->
                <Label Content="JAINA" 
       HorizontalAlignment="Left" 
       VerticalAlignment="Top" 
       Margin="71,332,0,0"
       Width="558">
                    <Label.Style>
                        <Style TargetType="Label">
                            <Setter Property="FontFamily" Value="Agit"/>
                            <Setter Property="FontSize" Value="58"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect 
                        ShadowDepth="3"
                        Direction="330"
                        Color="#FF2C3E50"
                        Opacity="0.6"
                        BlurRadius="10"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFFFFFFF" Offset="0.0"/>
                                        <GradientStop Color="#FFE0E0E0" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation 
                        Storyboard.TargetProperty="(Label.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                        To="1.05" Duration="0:0:0.2"/>
                                                <DoubleAnimation 
                        Storyboard.TargetProperty="(Label.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                        To="1.05" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation 
                        Storyboard.TargetProperty="(Label.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                        To="1" Duration="0:0:0.2"/>
                                                <DoubleAnimation 
                        Storyboard.TargetProperty="(Label.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                        To="1" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </Style.Triggers>

                        </Style>
                    </Label.Style>
                    <Label.Triggers>
                        <EventTrigger RoutedEvent="Label.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation 
                        Storyboard.TargetProperty="Opacity"
                        From="0" To="1" 
                        Duration="0:0:1">
                                        <DoubleAnimation.EasingFunction>
                                            <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Label.Triggers>
                    <Label.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Label.RenderTransform>
                </Label>

                <!-- Анимируемая надпись -->
                <Label x:Name="GreetingLabel" Content="Чем я могу тебе помочь?" 
                       HorizontalAlignment="Left" FontSize="14" Foreground="#FFCECECE" 
                       FontFamily="Abrade-ExtraLight" Margin="339,500,0,0" VerticalAlignment="Top" />

                <!-- Анимация для текста -->
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Grid.Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetName="GreetingLabel"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0.0" To="1.0"
                                                 Duration="0:0:2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
            </Grid>
        </Border>
    </Grid>

    <!-- Анимация -->
    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <!-- Переход для Stop1 -->
                    <ColorAnimation Storyboard.TargetName="Stop1" 
                                    Storyboard.TargetProperty="Color" 
                                    To="#08162f" 
                                    Duration="0:0:5" />

                    <!-- Переход для Stop2 -->
                    <ColorAnimation Storyboard.TargetName="Stop2" 
                                    Storyboard.TargetProperty="Color" 
                                    To="#007eff" 
                                    Duration="0:0:5" />

                    <!-- Добавляем новые эффекты -->
                    <ColorAnimation Storyboard.TargetName="Stop1" 
                                    Storyboard.TargetProperty="Color" 
                                    To="#08162f" 
                                    BeginTime="0:0:5" 
                                    Duration="0:0:5" />

                    <ColorAnimation Storyboard.TargetName="Stop2" 
                                    Storyboard.TargetProperty="Color" 
                                    To="#08162f" 
                                    BeginTime="0:0:5" 
                                    Duration="0:0:5" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>
</Page>
