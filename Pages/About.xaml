            ShadowDepth="0" 
            Opacity="0.7"/>
            </Label.Effect>
            <Label.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation 
                        Storyboard.TargetProperty="(Effect).Opacity"
                        From="0.7" To="1" 
                        Duration="0:0:2"
                        AutoReverse="True"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Label.Triggers>
        </Label>

        <Label Content="Версия 1.1.3 PreRelese" 
       HorizontalAlignment="Left" 
       Margin="537,48,0,0" 
       VerticalAlignment="Top" 
       FontFamily="Arial" 
       FontSize="12">
            <Label.Foreground>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF7100FF" Offset="0"/>
                    <GradientStop Color="#00a2ff" Offset="1"/>
                </LinearGradientBrush>
            </Label.Foreground>
            <Label.Effect>
                <DropShadowEffect 
            BlurRadius="15" 
            Color="#FF7100FF" 
            ShadowDepth="0" 
            Opacity="0.5"/>
            </Label.Effect>
        </Label>

        <!-- Ссылки на лицензии и другие ресурсы -->
        <!-- Лицензия -->
        <Label Content="Лицензия" 
       HorizontalAlignment="Left" 
       Margin="558,173,0,0" 
       VerticalAlignment="Top" 
       Foreground="#00a2ff" 
       FontFamily="Arial" 
       FontSize="14">
            <Label.Effect>
                <DropShadowEffect BlurRadius="10" Color="#00a2ff" ShadowDepth="0" Opacity="0.3"/>
            </Label.Effect>
        </Label>
        <Rectangle x:Name="LicenseLink" 
           HorizontalAlignment="Left" 
           Height="1" 
           Margin="558,195,0,0" 
