        <!-- Сообщить об ошибке -->
        <Label Content="Сообщить об ошибке" 
       HorizontalAlignment="Left" 
       Margin="558,224,0,0" 
       VerticalAlignment="Top" 
       Foreground="#00a2ff" 
       FontFamily="Arial" 
       FontSize="14">
            <Label.Effect>
                <DropShadowEffect BlurRadius="10" Color="#00a2ff" ShadowDepth="0" Opacity="0.3"/>
            </Label.Effect>
        </Label>
        <Rectangle x:Name="IssuesLink" 
           HorizontalAlignment="Left" 
           Height="1" 
           Margin="558,246,0,0" 
           Stroke="#00a2ff" 
           VerticalAlignment="Top" 
           Width="145" 
           Visibility="Hidden">
            <Rectangle.Effect>
                <DropShadowEffect BlurRadius="10" Color="#00a2ff" ShadowDepth="0" Opacity="0.7"/>
            </Rectangle.Effect>
        </Rectangle>
        <Rectangle Fill="Transparent" 
           Margin="558,232,0,0" 
           Width="170" 
           Height="12" 
           HorizontalAlignment="Left" 
           VerticalAlignment="Top" 
           MouseEnter="issuesLinkMouseEnter" 
           MouseLeave="issuesLinkMouseLeave" 
           MouseDown="issuesLinkClick"/>

        <!-- Официальный сайт -->
        <Label Content="Официальный сайт" 
       HorizontalAlignment="Left" 
       Margin="558,249,0,0" 
       VerticalAlignment="Top" 
       Foreground="#00a2ff" 
       FontFamily="Arial" 
       FontSize="14">
            <Label.Effect>
                <DropShadowEffect BlurRadius="10" Color="#00a2ff" ShadowDepth="0" Opacity="0.3"/>
            </Label.Effect>
        </Label>
        <Rectangle x:Name="SiteLink" 
           HorizontalAlignment="Left" 
           Height="1" 
           Margin="558,271,0,0" 
           Stroke="#00a2ff" 
           VerticalAlignment="Top" 
           Width="135" 
           Visibility="Hidden">
            <Rectangle.Effect>
                <DropShadowEffect BlurRadius="10" Color="#00a2ff" ShadowDepth="0" Opacity="0.7"/>
            </Rectangle.Effect>
        </Rectangle>
        <Rectangle Fill="Transparent" 
           Margin="558,256,0,0" 
           Width="157" 
           Height="13" 
           HorizontalAlignment="Left" 
           VerticalAlignment="Top" 
           MouseEnter="siteLinkMouseEnter" 
           MouseLeave="siteLinkMouseLeave" 
           MouseDown="siteLinkClick"/>

        <!-- Умения -->
        <Label Content="Умения" 
       HorizontalAlignment="Left" 
       Margin="558,274,0,0" 
       VerticalAlignment="Top" 
       Foreground="#00a2ff" 
       FontFamily="Arial" 
       FontSize="14">
            <Label.Effect>
                <DropShadowEffect BlurRadius="10" Color="#00a2ff" ShadowDepth="0" Opacity="0.3"/>
            </Label.Effect>
        </Label>
        <Rectangle x:Name="SkillsLink" 
           HorizontalAlignment="Left" 
           Height="1" 
           Margin="558,296,0,0" 
           Stroke="#00a2ff" 
           VerticalAlignment="Top" 
           Width="55" 
           Visibility="Hidden">
            <Rectangle.Effect>
                <DropShadowEffect BlurRadius="10" Color="#00a2ff" ShadowDepth="0" Opacity="0.7"/>
